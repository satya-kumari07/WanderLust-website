<% layout("/layouts/boilerplate") %>
<body>
    <h3>Edit your Lisitng</h3>
     <form method="POST" action="/listings/<%=listings._id%>?_method=PUT">
        <input type="text" name="listing[title]" value="<%=listings.title%>">
        <br><br>
        <textarea name="listing[description]"><%=listings.description%></textarea>
        <br><br>
        <input type="text" name="listing[image]" value="<%=listings.image%>">
        <br>  <br>
        <input type="number" name="listing[price]" value="<%=listings.price%>">
        <br>  <br>
        <input type="text" name="listing[location]" value="<%=listings.location%>">
        <br>  <br>
        <input type="text" name="listing[country]" value="<%=listings.country%>">
        <br>  <br>
        <button>Add</button>
    </form>
</body>