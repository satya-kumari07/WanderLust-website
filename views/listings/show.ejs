<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-6 offset-3 ">
            <h3>Listings Details :</h3>
        </div>
        <div class="card col-6 offset-3">
            <img src="<%=listings.image%>" class="card-img-top show-img" alt="listing-image">
                <div class="car-body">
                    <p class="card-text">
                        <b><%=listings.title%></b><br>
                        <%=listings.description%><br>
                        &#8377;<%=listings.price.toLocaleString("en-IN")%><br>
                        <%=listings.location%><br>
                        <%=listings.country%>
                    </p>
                </div>
            </div>
        </div>
        <div class="btn offset-3 mb-4">
            <a href="/listings/<%=listings._id%>/edit" class="btn btn-dark edit">Edit</a>
            <form method="POST" action="/listings/<%=listings._id%>?_method=DELETE">
                <button class="btn del-btn">Delete</button>
            </form>
        </div>
    </div>
</body>
